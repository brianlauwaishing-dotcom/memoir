# Copy to backend/.env (gitignored) and fill in real values.

# === Server ===
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=dev

# === Database (PostgreSQL) ===
DB_URL=jdbc:postgresql://localhost:5432/memoir
DB_USERNAME=memoir
DB_PASSWORD=memoir

# === Redis ===
REDIS_HOST=localhost
REDIS_PORT=6379

# === LLM (DeepSeek) ===
# Get key at https://platform.deepseek.com/api_keys
LLM_PROVIDER=deepseek
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT=60
